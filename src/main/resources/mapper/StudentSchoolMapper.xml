<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.csee.swplus.mileage.user.mapper.StudentSchoolMapper">

    <!--
        STYPE LOOKUP QUERY
        ==================
        Resolves the student type (stype) for a user based on their school, major1, and major2.
        Uses _sw_mileage_student_school as a lookup table. Does NOT create new rows.
        If no matching row is found, returns '기타' (Other).

        HOW THE MATCHING WORKS:
        ======================
        - Blank/NULL in the lookup table = "match any" (wildcard).
        - school:  Matches if r.school is blank OR equals the user's department.
        - major_1: Matches if r.major_1 is blank OR user's major1 starts with r.major_1 (prefix)
                   OR equals exactly. (e.g. r.major_1='CS' matches major1='Computer Science')
        - major_2: Same logic as major_1 for the second major field.

        MATCH PRIORITY (ORDER BY):
        ==========================
        Rows are sorted so the MOST SPECIFIC match wins:
        - Count non-empty columns in the lookup row (school, major_1, major_2).
        - Higher count = more specific (e.g. school+major1+major2 > school only).
        - Among ties, lower r.id wins (first inserted rule takes precedence).

        EXAMPLE:
        - User: school='CSEE', major1='Computer Science', major2='AI'
        - Row A: school='CSEE', major_1='Computer', major_2=NULL  -> matches, specificity=2
        - Row B: school='CSEE', major_1=NULL, major_2=NULL         -> matches, specificity=1
        - Row A wins (more specific).
    -->
    <select id="findStype" resultType="String">
        SELECT COALESCE(
            (SELECT r.stype
             FROM _sw_mileage_student_school r
             WHERE (r.school IS NULL OR r.school = '' OR r.school = #{school})
               AND (r.major_1 IS NULL OR r.major_1 = ''
                    OR (#{major1} IS NOT NULL AND (#{major1} LIKE CONCAT(r.major_1, '%') OR #{major1} = r.major_1)))
               AND (r.major_2 IS NULL OR r.major_2 = ''
                    OR (#{major2} IS NOT NULL AND (#{major2} LIKE CONCAT(r.major_2, '%') OR #{major2} = r.major_2)))
             ORDER BY (CASE WHEN COALESCE(r.school,'') != '' THEN 1 ELSE 0 END)
                    + (CASE WHEN COALESCE(r.major_1,'') != '' THEN 1 ELSE 0 END)
                    + (CASE WHEN COALESCE(r.major_2,'') != '' THEN 1 ELSE 0 END) DESC,
                    r.id ASC
             LIMIT 1),
            '기타'  <!-- TODO: Extract default stype to config/property (e.g. application.yml) instead of hardcoding -->
        )
    </select>

</mapper>

